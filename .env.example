# Copia este archivo a `.env` y rellena los valores antes de arrancar en local.
# Nunca subas `.env` al repositorio.

# Contraseña compartida del centro (modo local, sin Supabase)
VITE_APP_PASSWORD=tu-contraseña-segura

# Contraseña de administrador (modificar y eliminar registros)
VITE_ADMIN_PASSWORD=tu-contraseña-admin

# Supabase (opcional; si están configuradas, sustituyen el modo local)
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key
VITE_SUPABASE_AUTH_EMAIL=centro@appincidencias.local
